---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A focused personal site hosted on GitHub Pages." } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="backdrop" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/">freeofmoney.pro</a>
      <nav>
        <a href="#about">About</a>
        <a href="#now">Now</a>
        <a href="#projects">Projects</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Built with Astro. Hosted on GitHub Pages.</p>
    </footer>
  </body>
</html>
